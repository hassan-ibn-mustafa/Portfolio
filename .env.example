# Copy this to .env and fill in your values
# NEVER commit .env to git

# Supabase configuration (get from https://supabase.com > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The email address of the admin (must match the account you create in Supabase Auth)
VITE_ADMIN_EMAIL=your-email@example.com

# GitHub Pages base URL — set this to /your-repo-name/ for project pages
# Leave as / for username.github.io repos
VITE_BASE_URL=/portfolio/
